# ============================================================
# Server Analytics — Configuracion
# ============================================================
# 1. Copia este archivo a .env
# 2. Rellena tus datos
# 3. Ejecuta desde tu PC: python3 deploy/install.py
#
# Este es el UNICO archivo que necesitas modificar.
# SECRET_KEY y API_KEY se generan automaticamente si los dejas vacios.
# ============================================================

# Django (dejar vacios para auto-generar)
SECRET_KEY=
API_KEY=
DEBUG=False
ALLOWED_HOSTS=tu-dominio.com

# Telegram (opcional, para notificaciones de bloqueos)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Tu sitio
SITE_DOMAIN=https://tu-dominio.com
SITE_AUTHOR=Tu-Nombre
SITE_AUTHOR_URL=https://tu-web.com

# IPs excluidas del analizador de logs (tu IP + localhost)
WHITELIST_IPS=127.0.0.1,::1,TU-IP-PUBLICA-AQUI

# ============================================================
# Servidor remoto (SSH)
# ============================================================
SSH_HOST=IP-DE-TU-SERVIDOR
SSH_USER=root
SSH_PORT=22
# Contraseña SSH (opcional, si no tienes clave SSH configurada)
# Se recomienda borrar este campo despues del despliegue
SSH_PASSWORD=

# ============================================================
# Despliegue
# ============================================================
DEPLOY_USER=serveranalytics
DEPLOY_EMAIL=tu-email@ejemplo.com

# Metodo de despliegue: repo (clonar desde git) o upload (subir proyecto local)
DEPLOY_METHOD=upload
DEPLOY_REPO=https://github.com/tu-usuario/server-analytics.git
